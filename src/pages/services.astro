      transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  html.has-scroll-reveal .reveal-service-row.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
