<script is:inline>
  const initServicesReveal = () => {
    const rows = Array.from(document.querySelectorAll('.reveal-service-row'));
    if (!rows.length) return;

    document.documentElement.classList.add('has-scroll-reveal');

    // Ensure consistent initial state on each page load.
    rows.forEach((row, index) => {
      const isLeft = index % 2 === 0;
      row.setAttribute('data-reveal-index', String(index));
      row.setAttribute('data-reveal-side', isLeft ? 'left' : 'right');
      row.style.setProperty('--reveal-shift-x', isLeft ? '-72px' : '72px');
      row.classList.remove('is-visible');
    });

    const existingObserver = window.__servicesRevealObserver;
    if (existingObserver) existingObserver.disconnect();

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const element = entry.target;
          const index = Number(element.getAttribute('data-reveal-index') ?? 0);
          window.setTimeout(() => {
            element.classList.add('is-visible');
          }, Math.min(index * 55, 420));
          obs.unobserve(element);
        });
      },
      { rootMargin: '0px 0px -4% 0px', threshold: 0.35 }
    );

    rows.forEach((row, index) => {
      const rect = row.getBoundingClientRect();
      const inInitialViewport = rect.top < window.innerHeight * 0.92;

      if (inInitialViewport) {
        window.setTimeout(() => row.classList.add('is-visible'), Math.min(index * 40, 180));
        return;
      }

      observer.observe(row);
    });

    window.__servicesRevealObserver = observer;

    // Safety net: never leave rows hidden if observer misses an entry.
    window.setTimeout(() => {
      rows.forEach((row) => row.classList.add('is-visible'));
      observer.disconnect();
    }, 1800);
  };

  const listenersBound = window.__servicesRevealListenersBound;
  if (!listenersBound) {
    document.addEventListener('DOMContentLoaded', initServicesReveal);
    document.addEventListener('astro:page-load', initServicesReveal);
    window.__servicesRevealListenersBound = true;
  }

  initServicesReveal();
</script>
