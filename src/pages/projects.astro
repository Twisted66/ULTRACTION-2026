<script>
  // Carousel/Filter functionality
  const filterBtns = document.querySelectorAll('.filter-btn');
  const filterTargets = document.querySelectorAll('#projects-grid > [data-category]');
  const projectsGrid = document.getElementById('projects-grid');
  const filterStatus = document.getElementById('projects-filter-status');
  const prefersReducedFilterMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const FILTER_TRANSITION_MS = 180;
  let activeFilter = 'all';
  let pendingFilter = 'all';
  let filterTransitionTimer = 0;

  const formatFilterLabel = (filter: string): string => {
    if (!filter || filter === 'all') return 'all';
    return filter.replace('-', ' ');
  };

  const setActiveFilterButton = (activeFilter: string): void => {
    filterBtns.forEach((b) => {
      if (!(b instanceof HTMLElement)) return;
      const isActive = b.dataset.filter === activeFilter;
      b.classList.toggle('active', isActive);
      b.classList.toggle('bg-primary', isActive);
      b.classList.toggle('text-white', isActive);
      b.classList.toggle('bg-background', !isActive);
      b.classList.toggle('dark:bg-card', !isActive);
      b.classList.toggle('text-black', !isActive);
      b.setAttribute('aria-pressed', String(isActive));
    });
  };

  const applyFilter = (filter: string): number => {
    let visibleCount = 0;

    filterTargets.forEach((target) => {
      if (!(target instanceof HTMLElement)) return;
      const categories = (target.dataset.category ?? '').split(/\s+/).filter(Boolean);
      const isMatch = filter === 'all' || categories.includes(filter);

      if (isMatch) {
        target.hidden = false;
        target.removeAttribute('aria-hidden');
        visibleCount += 1;
      } else {
        target.hidden = true;
        target.setAttribute('aria-hidden', 'true');
      }
    });

    return visibleCount;
  };

  const updateFilterStatus = (filter: string, visibleCount: number): void => {
    if (!filterStatus) return;
    filterStatus.textContent = `Showing ${formatFilterLabel(filter)} projects (${visibleCount} sections visible).`;
  };

  const updateEmptyState = (filter: string, visibleCount: number): void => {
    if (!(projectsGrid instanceof HTMLElement)) return;
    let emptyState = projectsGrid.querySelector('[data-projects-empty-state]');

    if (!(emptyState instanceof HTMLElement)) {
      emptyState = document.createElement('div');
      emptyState.setAttribute('data-projects-empty-state', 'true');
      emptyState.className =
        'col-span-12 border-t border-border px-6 py-16 md:py-20 text-center text-primary bg-background';
      projectsGrid.appendChild(emptyState);
    }

    if (visibleCount > 0) {
      emptyState.hidden = true;
      emptyState.setAttribute('aria-hidden', 'true');
      emptyState.textContent = '';
      return;
    }

    emptyState.hidden = false;
    emptyState.removeAttribute('aria-hidden');
    emptyState.textContent = `No ${formatFilterLabel(filter)} projects in this featured visual grid yet.`;
  };

  const animateVisibleSections = (): void => {
    if (prefersReducedFilterMotion) return;
    let staggerIndex = 0;

    filterTargets.forEach((target) => {
      if (!(target instanceof HTMLElement) || target.hidden) return;
      target.style.setProperty('--filter-delay', `${staggerIndex * 45}ms`);
      target.classList.add('is-filter-entering');

      window.requestAnimationFrame(() => {
        target.classList.remove('is-filter-entering');
      });

      staggerIndex += 1;
    });
  };

  const commitFilter = (filter: string): void => {
    const visibleCount = applyFilter(filter);
    updateEmptyState(filter, visibleCount);
    updateFilterStatus(filter, visibleCount);
  };

  const transitionFilter = (filter: string): void => {
    if (filter === activeFilter && filterTransitionTimer === 0) return;
    pendingFilter = filter;

    if (filterTransitionTimer) {
      window.clearTimeout(filterTransitionTimer);
      filterTransitionTimer = 0;
    }

    if (!(projectsGrid instanceof HTMLElement) || prefersReducedFilterMotion) {
      commitFilter(filter);
      activeFilter = filter;
      pendingFilter = filter;
      return;
    }

    projectsGrid.classList.add('is-filter-transitioning');
    filterTransitionTimer = window.setTimeout(() => {
      commitFilter(pendingFilter);
      activeFilter = pendingFilter;
      projectsGrid.classList.remove('is-filter-transitioning');
      animateVisibleSections();
      filterTransitionTimer = 0;
    }, FILTER_TRANSITION_MS);
  };

  filterBtns.forEach((btn) => {
    if (!(btn instanceof HTMLElement)) return;
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      if (!filter) return;

      setActiveFilterButton(filter);
      transitionFilter(filter);
    });
  });

  // Initial empty-state sync for the default "all" view.
  setActiveFilterButton('all');
  commitFilter('all');

  // Center list smooth carousel
  const projectListCarousel = document.getElementById('projects-list-carousel');
  const projectListTrack = document.getElementById('projects-list-track');
  const projectListPages = document.querySelectorAll('.projects-list-slide');
  const projectListDots = document.querySelectorAll('.projects-list-dot');
  const projectListPrev = document.querySelector('[data-projects-prev]');
  const projectListNext = document.querySelector('[data-projects-next]');
  const projectListToggle = document.querySelector('[data-projects-toggle]');
  const projectListToggleLabel = projectListToggle?.querySelector('[data-projects-toggle-label]');
  const projectListStatus = document.getElementById('projects-list-status');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let projectListActiveIndex = 0;
  let projectListTimer = 0;
  let projectListPausedByUser = true;

  const setProjectListPage = (targetIndex: number, announce = true): void => {
    if (!(projectListTrack instanceof HTMLElement) || projectListPages.length === 0) return;
    const pageCount = projectListPages.length;
    const nextIndex = ((targetIndex % pageCount) + pageCount) % pageCount;
    projectListActiveIndex = nextIndex;
    projectListTrack.style.transform = `translateX(-${nextIndex * 100}%)`;

    projectListPages.forEach((page, pageIndex) => {
      if (!(page instanceof HTMLElement)) return;
      const isActive = pageIndex === nextIndex;
      page.setAttribute('aria-hidden', String(!isActive));
    });

    projectListDots.forEach((dot, dotIndex) => {
      if (!(dot instanceof HTMLElement)) return;
      const isActive = dotIndex === nextIndex;
      dot.setAttribute('aria-selected', String(isActive));
      dot.classList.toggle('bg-primary', isActive);
      dot.classList.toggle('scale-110', isActive);
      dot.classList.toggle('bg-transparent', !isActive);
      dot.classList.toggle('opacity-50', !isActive);
      dot.classList.toggle('hover:opacity-100', !isActive);
    });

    if (projectListStatus && announce) {
      projectListStatus.textContent = `Showing projects page ${nextIndex + 1} of ${projectListPages.length}.`;
    }
  };

  const stopProjectListAutoplay = () => {
    if (projectListTimer) {
      window.clearInterval(projectListTimer);
      projectListTimer = 0;
    }
  };

  const startProjectListAutoplay = () => {
    if (prefersReducedMotion || projectListPages.length <= 1 || projectListPausedByUser) return;
    stopProjectListAutoplay();
    projectListTimer = window.setInterval(() => {
      setProjectListPage(projectListActiveIndex + 1, false);
    }, 4500);
  };

  const updateProjectListToggle = () => {
    if (!(projectListToggle instanceof HTMLElement)) return;
    projectListToggle.setAttribute('aria-pressed', String(projectListPausedByUser));
    const label = projectListPausedByUser ? 'Play' : 'Pause';
    projectListToggle.setAttribute('aria-label', `${label} project list autoplay`);
    if (projectListToggleLabel instanceof HTMLElement) {
      projectListToggleLabel.textContent = label;
    } else {
      projectListToggle.textContent = label;
    }

    if (prefersReducedMotion) {
      projectListToggle.setAttribute('disabled', 'true');
      projectListToggle.setAttribute('title', 'Autoplay is disabled while reduced motion is enabled.');
    } else {
      projectListToggle.removeAttribute('disabled');
      projectListToggle.removeAttribute('title');
    }
  };

  projectListDots.forEach((dot) => {
    if (!(dot instanceof HTMLElement)) return;
    dot.addEventListener('click', () => {
      const targetIndex = Number(dot.dataset.projectPageTarget ?? 0);
      if (Number.isNaN(targetIndex)) return;
      setProjectListPage(targetIndex);
      startProjectListAutoplay();
    });
  });

  if (projectListPrev instanceof HTMLElement) {
    projectListPrev.addEventListener('click', () => {
      setProjectListPage(projectListActiveIndex - 1);
      startProjectListAutoplay();
    });
  }

  if (projectListNext instanceof HTMLElement) {
    projectListNext.addEventListener('click', () => {
      setProjectListPage(projectListActiveIndex + 1);
      startProjectListAutoplay();
    });
  }

  if (projectListCarousel instanceof HTMLElement) {
    projectListCarousel.addEventListener('mouseenter', stopProjectListAutoplay);
    projectListCarousel.addEventListener('mouseleave', () => {
      if (!projectListPausedByUser) startProjectListAutoplay();
    });
    projectListCarousel.addEventListener('focusin', stopProjectListAutoplay);
    projectListCarousel.addEventListener('focusout', () => {
      if (!projectListPausedByUser) startProjectListAutoplay();
    });
  }

  if (projectListToggle instanceof HTMLElement) {
    projectListToggle.addEventListener('click', () => {
      if (prefersReducedMotion) return;
      projectListPausedByUser = !projectListPausedByUser;
      updateProjectListToggle();

      if (projectListPausedByUser) {
        stopProjectListAutoplay();
      } else {
        startProjectListAutoplay();
      }
    });
  }

  updateProjectListToggle();
  setProjectListPage(0, false);
  startProjectListAutoplay();
</script>

<script>
  // Direction-Aware Hover for Project Cards
  function initDirectionAwareHover() {
    const cards = document.querySelectorAll('.project-card');

    cards.forEach((card) => {
      const overlay = card.querySelector('.project-overlay');
      if (!overlay || !(card instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;

      const getDirection = (e: MouseEvent): string => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        // Determine which edge the mouse is closest to
        const d = Math.atan2(y, x);
        // Convert to 0-3 range: 0=right, 1=bottom, 2=left, 3=top
        const direction = Math.round((d + Math.PI) / (Math.PI / 2)) % 4;
        return ['left', 'bottom', 'right', 'top'][direction];
      };

      card.addEventListener('mouseenter', (e: MouseEvent) => {
        const dir = getDirection(e);
        overlay.setAttribute('data-direction', dir);
        // Force reflow before adding visible class
        void overlay.offsetWidth;
        overlay.classList.add('is-visible');
      });

      card.addEventListener('mouseleave', (e: MouseEvent) => {
        const dir = getDirection(e);
        overlay.classList.remove('is-visible');
        overlay.setAttribute('data-direction', dir);
      });
    });
  }

  // Initialize on page load and Astro page transitions
