---
// Projects page - ULTRACTION General Contracting LLC
// Following Nova Construct prototype exactly

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SectionBackground from '../components/common/SectionBackground';

// SEO Metadata
const title = "Projects - ULTRACTION GENERAL CONTRACTING LLC";
const description = "Explore our portfolio of completed construction projects including residential, commercial, industrial, infrastructure, and renovation developments across the UAE.";

const allProjects = await getCollection('projects');
const projectEntries = allProjects
  .map((project) => ({
    slug: project.slug,
    title: project.data.title
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const projectChunkSize = Math.max(1, Math.ceil(projectEntries.length / 4));
const projectCarouselPages = Array.from({ length: 4 }, (_, pageIndex) =>
  projectEntries.slice(pageIndex * projectChunkSize, (pageIndex + 1) * projectChunkSize)
).filter((page) => page.length > 0);
const projectsLogoSrc = `${import.meta.env.BASE_URL}logo/UGC-LOGO-HQ.png`;
const projectsLogoFallbackSrc = `${import.meta.env.BASE_URL}logo/UGC-HEADER.png`;
---

<Layout
  title={title}
  description={description}
  image="/logo/UGC-HEADER.png"
>
  <!-- Hero Section - 2 Column Layout (Matching About/Services) -->
  <!-- Hero Section - Full Width Video Background -->
  <!-- Hero Section - 1:1 Split Layout -->
  <section class="grid grid-cols-1 lg:grid-cols-2 border-t border-b border-border min-h-[75vh] lg:min-h-[85vh]">
    <!-- Left Column: Text -->
    <div class="flex flex-col justify-center px-6 py-16 md:px-12 lg:p-24 border-r border-border relative bg-surface h-full">
      <span class="text-xs font-bold uppercase tracking-widest opacity-80 mb-4 block">Strategic Portfolio</span>
      <h1 class="text-5xl lg:text-7xl font-bold uppercase leading-none mb-12 font-heading hero-text-reveal opacity-0">
        Precision in <br/> <span class="text-accent italic">Execution</span>
      </h1>
      <div class="w-12 h-[1px] bg-foreground/20 mb-8"></div>
      <p class="text-lg mb-6 opacity-80 leading-relaxed max-w-sm text-foreground">
        Explore a distinguished record of structural excellence across the UAE. From complex infrastructure and industrial facilities to precision-engineered residential developments, our portfolio reflects a legacy of transformative growth and unwavering quality.
      </p>
    </div>

    <!-- Right Column: HD Standalone Image (100% Occupancy) -->
    <div class="relative overflow-hidden min-h-[280px] sm:min-h-[360px] lg:h-full bg-surface">
      <img 
        src="/images/projects-hero-v2.png" 
        alt="Naseem Al Bar Bridge construction project" 
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      {/* Sophisticated brand overlays */}
      <div class="absolute inset-0 pointer-events-none bg-gradient-to-r from-surface via-surface/40 to-transparent z-10"></div>
      <div class="absolute inset-0 pointer-events-none bg-black/5 mix-blend-multiply z-10"></div>
      <div class="absolute inset-0 pointer-events-none border-l border-foreground/5 z-20"></div>
    </div>
  </section>

  <!-- Filters Section - Full Width -->
  <section class="border-b border-border">
    <div class="grid grid-cols-4 md:grid-cols-8" role="group" aria-label="Filter projects by category">
      <!-- ALL PROJECTS - Active -->
      <button
        type="button"
        data-filter="all"
        aria-pressed="true"
        aria-controls="projects-grid"
        class="filter-btn active h-24 border-r border-b md:border-b-0 border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-primary text-white"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M4 4h6v6H4V4zm10 0h6v6h-6V4zM4 14h6v6H4v-6zm10 3h6m-3-3v6"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">ALL</span>
      </button>

      <!-- INFRASTRUCTURE - Inactive -->
      <button
        type="button"
        data-filter="infrastructure"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-b md:border-b-0 border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">INFRA</span>
      </button>

      <!-- MARINE - Inactive -->
      <button
        type="button"
        data-filter="marine"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-b md:border-b-0 border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M4 19h16M6 17l6-11 6 11M12 6V3m0 14v2"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">MARINE</span>
      </button>

      <!-- HERITAGE - Inactive -->
      <button
        type="button"
        data-filter="heritage"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-b md:border-b-0 border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 20h18M4 9l8-5 8 5M6 9v8m4-8v8m4-8v8m4-8v8"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">HERITAGE</span>
      </button>

      <!-- OIL & GAS - Inactive -->
      <button
        type="button"
        data-filter="oil-gas"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M8 6h8m-8 0a2 2 0 0 0-2 2v9a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V8a2 2 0 0 0-2-2m-8 4h8"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">OIL & GAS</span>
      </button>

      <!-- INDUSTRIAL - Inactive -->
      <button
        type="button"
        data-filter="industrial"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 20h18M4 20V9l4 3V9l4 3V7l9 4v9M8 20v-3m4 3v-3m4 3v-3"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">INDUSTRIAL</span>
      </button>

      <!-- RESIDENTIAL - Inactive -->
      <button
        type="button"
        data-filter="residential"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 border-r border-border flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background hover:bg-surface text-foreground"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 11l9-7 9 7M5 10v10h14V10M9 20v-5h6v5"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">RESIDENTIAL</span>
      </button>

      <!-- COMMERCIAL - Inactive -->
      <button
        type="button"
        data-filter="commercial"
        aria-pressed="false"
        aria-controls="projects-grid"
        class="filter-btn h-24 flex flex-col items-center justify-center gap-1 transition-all motion-base bg-background dark:bg-card text-black"
      >
        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 20h18M5 20V7h14v13M9 11h2m2 0h2m-6 4h2m2 0h2"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-wider">COMMERCIAL</span>
      </button>
    </div>
    <p id="projects-filter-status" class="sr-only" aria-live="polite">Showing all projects.</p>
  </section>

  <!-- Projects Grid - 2:1:2 Masonry Layout -->
  <section class="border-b border-border bg-background" aria-labelledby="projects-grid-heading">
    <h2 id="projects-grid-heading" class="sr-only">Featured Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-12 auto-rows-min items-start" id="projects-grid">

      <!-- Column 1 -->
      <div class="col-span-12 md:col-span-4 md:col-start-1 md:row-start-1 flex flex-col border-r border-border" data-category="infrastructure all">
        <div class="project-card relative group overflow-hidden min-h-[18rem] md:min-h-[24rem] border-b border-border">
          <img alt="Al Tallah Road Bridge Construction, Ajman" class="w-full h-full object-cover transition-transform motion-slow media-motion" src="/images/projects/al-tallah-bridge/photo_010.jpeg" />
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/30 transition-colors motion-base"></div>
          <div class="absolute bottom-4 left-4 right-4 z-20">
            <div class="p-4">
              <span class="text-[10px] uppercase tracking-widest block mb-1 text-white drop-shadow-md">Bridge Construction</span>
              <h3 class="text-lg font-bold uppercase leading-tight text-white drop-shadow-md">Al Tallah Road Bridge 1, 2 &amp; 3</h3>
              <div class="mt-2 flex justify-between items-end pt-2">
                <span class="text-[10px] opacity-70 text-white drop-shadow-sm">Ajman</span>
                <svg class="inline-flex w-4 h-4 text-white drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-6-6 6 6-6 6"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="project-overlay absolute inset-0 bg-primary/90 flex flex-col justify-center items-center text-white p-8 text-center z-30">
            <span class="text-[10px] uppercase tracking-widest text-white mb-2">Bridge Construction</span>
            <h3 class="text-2xl font-bold uppercase mb-3">Al Tallah Road Bridge 1, 2 &amp; 3</h3>
            <p class="text-xs opacity-90 mb-4 max-w-[260px]">Comprehensive bridge construction works delivering improved connectivity in Ajman, UAE.</p>
            <a href="/projects/3-bridges-al-talah-road" class="text-[10px] uppercase tracking-widest font-bold border border-white/30 px-4 py-2 hover:bg-white hover:text-primary transition-colors cursor-pointer">
              Explore
            </a>
          </div>
        </div>
        <div class="project-card relative group overflow-hidden min-h-[15rem] md:min-h-[21rem]">
          <img alt="E20 Traffic Improvement and Bridge Construction" class="w-full h-full object-cover transition-transform motion-slow media-motion" src="/images/projects/e20-traffic-bridges/photo_010.jpeg" />
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/30 transition-colors motion-base"></div>
          <div class="absolute bottom-4 left-4 z-20 text-white">
            <h3 class="text-lg font-bold uppercase mb-1 drop-shadow-md">Traffic Improvement E20</h3>
            <p class="text-[10px] uppercase tracking-wide opacity-90 drop-shadow-md">2 Bridges Construction</p>
          </div>
          <div class="project-overlay absolute inset-0 bg-primary/95 flex flex-col justify-center items-center text-white p-6 text-center z-30">
            <span class="text-[10px] uppercase tracking-widest text-white mb-2">Details</span>
            <h3 class="text-lg font-bold uppercase mb-3">E20 Traffic Improvement</h3>
            <div class="text-[11px] space-y-1 opacity-80">
              <p>Location: UAE</p>
              <p>Scope: Highway &amp; 2 Bridges</p>
            </div>
            <a href="/projects/traffic-improvement-e20" class="mt-4 text-[10px] uppercase tracking-widest font-bold border border-white/30 px-4 py-2 hover:bg-white hover:text-primary transition-colors cursor-pointer">
              Explore
            </a>
          </div>
        </div>
      </div>

      <!-- Column 2 - Company Logo & Projects List (Center) -->
      <div class="col-span-12 md:col-span-4 md:col-start-5 md:row-start-1 flex flex-col border-r border-border" data-category="all infrastructure marine heritage oil-gas industrial residential commercial">
        <div class="relative min-h-[30rem] md:min-h-[45rem] border-b md:border-b-0 border-border flex flex-col overflow-hidden">
          <!-- Logo Section -->
          <div class="min-h-[11rem] md:min-h-[12rem] flex items-center justify-center p-6 md:p-7 bg-background">
            <img
              alt="ULTRACTION GENERAL CONTRACTING LLC Logo"
              src={projectsLogoSrc}
              width="928"
              height="768"
              loading="eager"
              decoding="async"
              onerror={`this.onerror=null;this.src='${projectsLogoFallbackSrc}';`}
              class="max-w-full max-h-[210px] object-contain"
            />
          </div>

          <!-- Projects List -->
          <div class="p-5 md:p-6 pt-3 md:pt-4 text-center flex-1">
            <h3 class="text-sm font-bold uppercase tracking-widest mb-4 border-b border-border/20 pb-3 text-primary text-center">Our Projects</h3>
            <div id="projects-list-carousel" class="projects-list-carousel relative overflow-hidden min-h-[210px]">
              <div id="projects-list-track" class="projects-list-track flex">
                {projectCarouselPages.map((projectPage, pageIndex) => (
                  <div
                    id={`projects-list-page-${pageIndex}`}
                    class="projects-list-slide w-full shrink-0"
                    data-project-page={pageIndex}
                    aria-hidden={pageIndex === 0 ? 'false' : 'true'}
                  >
                    <ul class="space-y-0.5">
                      {projectPage.map((project) => (
                        <li>
                          <a href={`/projects/${project.slug}`} class="projects-list-link flex items-center justify-between gap-3 group py-1.5 text-primary transition-colors motion-base">
                            <span class="project-link-label text-[11px] uppercase tracking-wide text-left">{project.title}</span>
                            <svg class="inline-flex w-4 h-4 text-primary/70 group-hover:text-primary transition-all motion-base group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-6-6 6 6-6 6"/>
                            </svg>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-4 flex items-center justify-center gap-3">
              <button
                type="button"
                class="projects-list-nav inline-flex h-7 px-3 items-center justify-center rounded-full border border-primary/35 text-[10px] font-bold uppercase tracking-widest text-primary hover:bg-primary hover:text-white transition-colors motion-base"
                data-projects-toggle
                aria-label="Play project list autoplay"
                aria-pressed="true"
              >
                <span data-projects-toggle-label>Play</span>
              </button>
              <button
                type="button"
                class="projects-list-nav inline-flex h-7 w-7 items-center justify-center rounded-full border border-primary/35 text-primary hover:bg-primary hover:text-white transition-colors motion-base"
                data-projects-prev
                aria-label="Show previous projects"
              >
                <svg class="inline-flex w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m15 18-6-6 6-6"/>
                </svg>
              </button>
              <div role="tablist" aria-label="Project list pages" class="flex items-center justify-center gap-3">
              {projectCarouselPages.map((_, pageIndex) => (
                <button
                  type="button"
                  role="tab"
                  aria-controls={`projects-list-page-${pageIndex}`}
                  aria-selected={pageIndex === 0 ? 'true' : 'false'}
                  class={`projects-list-dot w-2.5 h-2.5 rounded-full border border-primary transition-all motion-base ${
                    pageIndex === 0 ? 'bg-primary scale-110' : 'bg-transparent opacity-50 hover:opacity-100'
                  }`}
                  data-project-page-target={pageIndex}
                >
                  <span class="sr-only">Show projects page {pageIndex + 1}</span>
                </button>
              ))}
              </div>
              <button
                type="button"
                class="projects-list-nav inline-flex h-7 w-7 items-center justify-center rounded-full border border-primary/35 text-primary hover:bg-primary hover:text-white transition-colors motion-base"
                data-projects-next
                aria-label="Show next projects"
              >
                <svg class="inline-flex w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m9 18 6-6-6-6"/>
                </svg>
              </button>
            </div>
            <p id="projects-list-status" class="sr-only" aria-live="polite">
              Showing projects page 1 of {projectCarouselPages.length}.
            </p>
            <a href="/projects" class="mt-4 inline-block text-[10px] uppercase tracking-widest font-bold border border-foreground/30 px-4 py-2 hover:bg-primary hover:text-white transition-colors text-primary">
              View All Projects
            </a>
          </div>
        </div>
      </div>

      <!-- Column 3 -->
      <div class="col-span-12 md:col-span-4 md:col-start-9 md:row-start-1 flex flex-col" data-category="marine all">
        <div class="project-card relative group overflow-hidden min-h-[15rem] md:min-h-[21rem] border-b border-border">
          <img alt="Khalifa Port Marine Infrastructure" class="w-full h-full object-cover transition-transform motion-slow media-motion" src="/images/projects/khalifa-port/hero.png" />
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors motion-base"></div>
          <div class="absolute top-4 right-4 z-20">
            <svg class="inline-flex w-5 h-5 text-white opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 17 17 7M9 7h8v8"/>
            </svg>
          </div>
          <div class="absolute bottom-0 left-0 w-full p-6 text-white z-20 bg-gradient-to-t from-black/80 to-transparent">
            <h3 class="text-xl font-bold uppercase mb-1">Khalifa Port</h3>
            <p class="text-xs uppercase tracking-widest opacity-80">Marine Works</p>
          </div>
          <div class="project-overlay absolute inset-0 bg-primary/95 flex flex-col justify-center items-center text-white p-6 text-center z-30">
            <h3 class="text-xl font-bold uppercase mb-2">Khalifa Port</h3>
            <p class="text-[10px] uppercase tracking-widest mb-2 opacity-80">Abu Dhabi / UAE</p>
            <span class="inline-block w-8 h-[1px] bg-white/40"></span>
            <p class="mt-3 text-xs opacity-90 max-w-[240px]">Major marine infrastructure delivery expanding one of the UAE's key deep-water ports.</p>
            <a href="/projects/khalifa-port" class="mt-4 text-[10px] uppercase tracking-widest font-bold border border-white/30 px-4 py-2 hover:bg-white hover:text-primary transition-colors cursor-pointer">
              Explore
            </a>
          </div>
        </div>
        <div class="project-card relative group overflow-hidden min-h-[18rem] md:min-h-[24rem]">
          <img alt="Marine Staging Yassat Island" class="w-full h-full object-cover transition-transform motion-slow media-motion" src="/images/projects/marine-staging-yassat-island/hero.png" />
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/30 transition-colors motion-base"></div>
          <div class="absolute top-6 left-6 z-20">
            <div class="flex flex-col items-start gap-1">
              <span class="text-3xl font-bold text-white uppercase leading-none">M2</span>
              <span class="h-[1px] w-8 bg-white/50"></span>
            </div>
          </div>
          <div class="absolute bottom-6 right-6 z-20 text-right">
            <h3 class="text-2xl font-bold text-white uppercase mb-1 leading-tight text-shadow-sm">Marine Staging<br/>Yassat Island</h3>
            <p class="text-[10px] text-white uppercase tracking-widest font-medium">Abu Dhabi Ports</p>
          </div>
          <div class="project-overlay absolute inset-0 bg-primary/90 flex flex-col justify-center items-center text-white p-8 text-center z-30">
            <svg class="w-12 h-12 mb-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"/>
            </svg>
            <h3 class="text-2xl font-bold uppercase mb-2">Marine Staging</h3>
            <p class="text-xs opacity-90 mb-4 max-w-[220px]">Specialized marine staging facility supporting offshore construction and logistics operations.</p>
            <a href="/projects/marine-staging-yassat-island" class="text-[10px] uppercase tracking-widest font-bold border border-white/30 px-4 py-2 hover:bg-white hover:text-primary transition-colors cursor-pointer">
              Explore
            </a>
          </div>
        </div>
      </div>

      <!-- Additional Projects Row -->
      <div class="col-span-12 md:col-span-4 md:col-start-1 md:row-start-2 flex flex-col border-r border-t border-border" data-category="commercial heritage all">
        <div class="project-card relative group overflow-hidden min-h-[17rem] md:min-h-[23rem] border-b border-border">
          <img alt="Dubai Marina Commercial Tower" class="w-full h-full object-cover transition-transform motion-slow media-motion" src="/images/projects/dubai-marina-tower/hero.png" />
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors motion-base"></div>
          <div class="absolute bottom-0 left-0 w-full p-6 text-white z-20 bg-gradient-to-t from-black/80 to-transparent">
            <span class="text-[10px] uppercase tracking-widest text-white">Commercial</span>
            <h3 class="text-xl font-bold uppercase mt-1">Dubai Marina Tower</h3>
            <p class="text-[10px] uppercase tracking-wide opacity-90 mt-1">High-Rise Construction</p>
          </div>
          <div class="project-overlay absolute inset-0 bg-primary/95 flex flex-col justify-center items-center text-white p-6 text-center z-30">
            <span class="text-[10px] uppercase tracking-widest text-white mb-2">Commercial</span>
            <h3 class="text-xl font-bold uppercase mb-3">Dubai Marina Tower</h3>
            <p class="text-xs opacity-90 mb-4 max-w-[240px]">Commercial tower delivery in Dubai Marina with integrated structural and finishing packages.</p>
            <a href="/projects/dubai-marina-tower" class="text-[10px] uppercase tracking-widest font-bold border border-white/30 px-4 py-2 hover:bg-white hover:text-primary transition-colors cursor-pointer">
              Explore
            </a>
          </div>
        </div>
        <div class="project-card relative group overflow-hidden min-h-[17rem] md:min-h-[23rem]">
