---
// ULTRACTION Core Values Section - Remotion Refactor
import { CoreValuesVideoPlayer } from '../../remotion/CoreValuesVideoPlayer';
---

<section
  class="relative isolate bg-surface border-y border-primary/20 overflow-hidden min-h-[90vh] md:min-h-screen flex flex-col"
  aria-labelledby="core-values-title"
  aria-describedby="core-values-intro"
  data-core-values
>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-20">
    <div
      class="absolute inset-0 opacity-[0.03]"
      style={{
        backgroundImage: `
          linear-gradient(to right, currentColor 1px, transparent 1px),
          linear-gradient(to bottom, currentColor 1px, transparent 1px)
        `,
        backgroundSize: '60px 60px'
      }}
    ></div>
    <div class="absolute top-0 left-1/4 h-96 w-96 rounded-full bg-accent/5 blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-primary/5 blur-3xl animate-pulse-slower"></div>
  </div>

  {/* Header Section */}
  <div class="relative z-10 w-full px-6 py-20 md:px-12 lg:px-24 bg-surface shadow-lg pb-16">
    <header class="grid grid-cols-12 gap-4">
      <div class="col-span-12 lg:col-span-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-[2px] bg-accent"></div>
          <span class="text-xs font-bold uppercase tracking-[0.3em] text-accent">Our Foundation</span>
        </div>
        <h2 id="core-values-title" class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-heading leading-[0.9] tracking-tight mb-6">
          Core
          <br />
          <span class="italic font-light text-primary/50 scale-y-75 inline-block">Values</span>
        </h2>
        <p id="core-values-intro" class="text-base md:text-lg text-primary/60 max-w-2xl leading-relaxed">
          The principles that guide every decision we make and every structure we build.
        </p>
      </div>
    </header>
  </div>

  {/* Remotion Brand Trailer Embed - Moved out of the background layer */}
  <div class="relative z-0 w-full shadow-2xl overflow-hidden bg-black h-[50vh] md:h-[60vh] xl:h-[70vh]">
    <div class="h-full w-full" data-core-values-video>
      <CoreValuesVideoPlayer client:load />
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-accent to-transparent z-20 pointer-events-none"></div>
</section>


<style>
  [data-core-values-video] :global(astro-island) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
