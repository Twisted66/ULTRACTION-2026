# ============================================================
# ULTRACTION.AE — Apache / cPanel Security & Performance Config
# ============================================================

# ----------------------------------------------------------------
# HTTP Security Headers
# ----------------------------------------------------------------
<IfModule mod_headers.c>
  # Strict Transport Security (HTTPS only; 1 year)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Prevent clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Block MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Referrer policy — send origin only on cross-origin requests
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy — disable unused browser APIs
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"

  # Cross-Origin Opener Policy
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # Content Security Policy
  # Allows: site assets, Google Fonts, Google Maps iframe embeds, globe texture CDN
  Header always set Content-Security-Policy "\
default-src 'self'; \
script-src 'self' 'unsafe-inline'; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
font-src 'self' https://fonts.gstatic.com data:; \
img-src 'self' data: blob: https://unpkg.com https://*.google.com https://*.gstatic.com; \
media-src 'self' blob:; \
connect-src 'self'; \
frame-src https://www.google.com https://maps.google.com; \
frame-ancestors 'self'; \
base-uri 'self'; \
form-action 'self'"

  # Remove X-Powered-By
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# ----------------------------------------------------------------
# Redirect HTTP → HTTPS
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ----------------------------------------------------------------
# Astro Static Site — Directory Index & 404 Handling
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve pre-built directory index files (Astro format: directory)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)$ %{REQUEST_FILENAME}/index.html [L]
</IfModule>

# ----------------------------------------------------------------
# Cache-Control for Static Assets
# ----------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Fonts & images — long cache
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"

  # JS & CSS — medium cache (versioned by Astro hashes)
  ExpiresByType text/css "access plus 3 months"
  ExpiresByType application/javascript "access plus 3 months"

  # HTML — short cache (content changes)
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ----------------------------------------------------------------
# Deny access to sensitive files/directories
# ----------------------------------------------------------------
<FilesMatch "(\.env|\.git|\.gitignore|package\.json|package-lock\.json|tsconfig\.json)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ----------------------------------------------------------------
# Disable directory listing
# ----------------------------------------------------------------
Options -Indexes

# ----------------------------------------------------------------
# Custom error pages (if applicable in future)
# ----------------------------------------------------------------
# ErrorDocument 404 /404/index.html
