# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/projects/
# Format: https://examplePublicKey@o0.ingest.sentry.io/projectId
SENTRY_DSN=your-sentry-dsn-here

# Environment (development, staging, production)
SENTRY_ENVIRONMENT=development

# Jobs API (Careers backend)
# Secret used by Custom GPT Actions (and any trusted automation) to mutate jobs.
JOBS_API_KEY=replace-with-strong-random-secret

# Optional database connection string for jobs storage.
# When unset or unavailable, the API falls back to JOBS_STORAGE_PATH.
JOBS_DATABASE_URL=

# Optional absolute/relative file path for jobs data persistence.
# Defaults to tmp/jobs-data.json
JOBS_STORAGE_PATH=tmp/jobs-data.json

# Optional public base URL for careers page jobs fetch.
# Keep empty for same-origin (/api/jobs), set when frontend and API run on different origins.
PUBLIC_JOBS_API_BASE_URL=

# News API (News & Insights backend)
# Secret used by Custom GPT Actions (and any trusted automation) to mutate news.
NEWS_API_KEY=replace-with-strong-random-secret

# Optional database connection string for news storage.
# When unset or unavailable, the API falls back to NEWS_STORAGE_PATH.
NEWS_DATABASE_URL=

# Optional absolute/relative file path for news data persistence.
# Defaults to tmp/news-data.json
NEWS_STORAGE_PATH=tmp/news-data.json

# Optional public base URL for News & Insights page fetch.
# Keep empty for same-origin (/api/news), set when frontend and API run on different origins.
PUBLIC_NEWS_API_BASE_URL=

# Microsoft Graph mail backend for Contact Us submissions
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_USER=info@ultraction.ae

# Optional receiver address for all contact submissions.
# Defaults to info@ultraction.ae when empty.
CONTACT_RECEIVER_EMAIL=
